# Local development:
# DATABASE_URL=sqlite:///./identity_coach.db

# Supabase Session Pooler:
DATABASE_URL=postgresql+psycopg://postgres.attrqdzflzbcblygqect:YOUR_DATABASE_PASSWORD@aws-1-eu-central-2.pooler.supabase.com:5432/postgres?sslmode=require

SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Allowed CORS origins (comma-separated). Keep explicit; do not use "*" together
# with credentials.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- AI / LLM layer ---------------------------------------------------------
# Provider: offline | gemini | openai | claude | ollama
# "offline" needs no key and produces deterministic coaching, so the app runs
# with zero configuration. Set a provider + its key to use a real model.
LLM_PROVIDER=offline
# LLM_MODEL=                     # leave empty for the provider's default
# EMBEDDING_PROVIDER=            # defaults to LLM_PROVIDER when empty
# EMBEDDING_MODEL=

# Only the key for the selected provider is needed. Never commit real keys.
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# Coaching guardrails
# COACH_REASON_MAX_CHARS=2000
# LLM_TIMEOUT_SECONDS=30
# AUTO_SEED_STRATEGIES=true
